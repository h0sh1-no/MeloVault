# Go backend server bind host
HOST=0.0.0.0

# Go backend server port
PORT=5000

# Download directory
DOWNLOADS_DIR=downloads

# Cookie file path
COOKIE_FILE=cookie.txt

# CORS origin policy
CORS_ORIGINS=*

# Database configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=change-me
DB_NAME=melovault
DB_SSLMODE=disable

# JWT configuration (generate with: openssl rand -base64 32)
JWT_SECRET=change-me-in-production
JWT_ACCESS_DURATION_MIN=15
JWT_REFRESH_DURATION_DAY=7

# Frontend URL (for OAuth redirects)
FRONTEND_URL=http://localhost:5000

# Linuxdo OAuth (get from https://connect.linux.do)
LINUXDO_CLIENT_ID=
LINUXDO_CLIENT_SECRET=
LINUXDO_REDIRECT_URI=http://localhost:5000/api/auth/linuxdo/callback

# SMTP configuration (optional, for email verification)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
